{
  "name": "invoiceflow-mcp-server",
  "version": "1.4.2",
  "mcpName": "io.github.enzoemir1/invoiceflow-mcp",
  "description": "AI-powered invoice automation for MCP. Create invoices, predict late payments, auto-remind, reconcile payments, and track cash flow.",
  "repository": {
    "type": "git",
    "url": "https://github.com/enzoemir1/invoiceflow-mcp.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "inspect": "npx @modelcontextprotocol/inspector npx tsx src/index.ts"
  },
  "keywords": [
    "mcp",
    "invoice",
    "billing",
    "ai",
    "payment",
    "stripe",
    "freelancer",
    "automation",
    "pdf",
    "cashflow"
  ],
  "author": "Automatia BCN",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "pdf-lib": "^1.17.1",
    "uuid": "^14.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}