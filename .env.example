# InvoiceFlow MCP — Environment Variables

# LemonSqueezy license key — unlocks Pro tools (invoice_send, invoice_risk,
# payment_reconcile, cashflow_report). Without it, InvoiceFlow runs in Free mode.
LEMONSQUEEZY_LICENSE_KEY=

# SendGrid (for sending invoice emails and reminders)
SENDGRID_API_KEY=
# Sender identity used on outbound email (defaults: noreply@invoiceflow.dev / InvoiceFlow)
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=

# Stripe — v2.0 roadmap, not yet active.
# payment_reconcile matches amounts you provide (CSV/webhook/manual); no live API call.
STRIPE_API_KEY=

# PayPal — v2.0 roadmap, not yet active (see Stripe note above).
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
